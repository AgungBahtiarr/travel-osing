---
// Layout Component
// Serves as the main HTML shell for Travel Osing pages.
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
	image?: string;
}

const {
	title = "Travel Osing - Jelajahi Pesona Banyuwangi | Sunrise of Java",
	description = "Travel Osing adalah agensi perjalanan premium di Banyuwangi. Temukan keindahan Kawah Ijen Blue Fire, Sabana Baluran, Pantai Pulau Merah, dan otentisitas kebudayaan suku Osing bersama pemandu lokal profesional.",
	image = "/images/hero_bg.png"
} = Astro.props;
---

<!DOCTYPE html>
<html lang="id">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- SEO Meta Tags -->
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="keywords" content="travel osing, travel banyuwangi, kawah ijen, blue fire, baluran, pulau merah, desa adat kemiren, suku osing, pariwisata banyuwangi" />
		<meta name="author" content="Travel Osing" />
		
		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={image} />
		
		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={image} />

		<!-- Premium Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,800;1,400&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
	</head>
	<body class="bg-bg-main text-text-main font-sans antialiased">
		<slot />
	</body>
</html>
