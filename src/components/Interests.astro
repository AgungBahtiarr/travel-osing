---
// Interests Component
// TripAdvisor-style "Find things to do by interest" section using Content Collections.
import { getCollection } from 'astro:content';
import { ChevronRight } from '@lucide/astro';
import { Image } from 'astro:assets';
import { useTranslations } from '../utils/i18n';

const locale = Astro.currentLocale || 'id';
const t = useTranslations(locale);

const interests = await getCollection('interests');
// Filter based on locale folder prefix (e.g. id/ or en/)
const filteredInterests = interests.filter(item => item.id.startsWith(`${locale}/`));
const sortedInterests = filteredInterests.sort((a, b) => a.data.sortOrder - b.data.sortOrder);
---

<section class="py-20 px-6 bg-bg-secondary border-t border-b border-border-color" id="minat">
  <div class="max-w-7xl mx-auto px-6 relative">
    
    <!-- TripAdvisor style Section Header -->
    <div class="text-left mb-10 max-w-[650px]">
      <span class="inline-block text-[0.75rem] font-bold uppercase tracking-[0.2em] text-primary mb-2.5">
        {t('interests.badge')}
      </span>
      <h2 class="font-sans text-3xl md:text-4xl text-text-main mb-3 font-black tracking-tight leading-tight">
        {t('interests.title')}
      </h2>
      <p class="text-text-muted text-base font-semibold">
        {t('interests.subtitle')}
      </p>
    </div>

    <!-- Horizontal Scrollable Row (Clean 1:1 Aspect TripAdvisor Squares) -->
    <div class="flex gap-6 overflow-x-auto no-scrollbar snap-x snap-mandatory py-4 px-1 scroll-smooth">
      
      {sortedInterests.map((interest) => (
        <a href={interest.data.link} class="w-[180px] sm:w-[220px] shrink-0 snap-start group text-center block">
          <div class="aspect-square rounded-2xl overflow-hidden border border-border-color shadow-sm bg-slate-100 mb-3.5 transition-all duration-300 group-hover:shadow-md group-hover:-translate-y-1">
            <Image class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-103" src={interest.data.image} alt={interest.data.title} width={300} height={300} loading="lazy" />
          </div>
          <span class="text-sm font-black text-text-main tracking-tight group-hover:text-primary transition-colors flex items-center justify-center gap-1">
            {interest.data.title}
            <ChevronRight class="w-3.5 h-3.5 opacity-0 group-hover:opacity-100 transition-all shrink-0" />
          </span>
        </a>
      ))}

    </div>
  </div>
</section>
