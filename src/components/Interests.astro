---
// Interests Component
// TripAdvisor-style "Find things to do by interest" section.
import { ChevronRight } from '@lucide/astro';
---

<section class="py-20 px-6 bg-bg-secondary border-t border-b border-border-color" id="minat">
  <div class="max-w-7xl mx-auto px-6 relative">
    
    <!-- TripAdvisor style Section Header -->
    <div class="text-left mb-10 max-w-[650px]">
      <span class="inline-block text-[0.75rem] font-bold uppercase tracking-[0.2em] text-primary mb-2.5">
        Temukan Pengalaman
      </span>
      <h2 class="font-sans text-3xl md:text-4xl text-text-main mb-3 font-black tracking-tight leading-tight">
        Cari Aktivitas Sesuai Minat Anda
      </h2>
      <p class="text-text-muted text-base font-semibold">
        Apa pun hobi atau kegemaran Anda, kami merancang petualangan yang tepat untuk Anda.
      </p>
    </div>

    <!-- Horizontal Scrollable Row (Clean 1:1 Aspect TripAdvisor Squares) -->
    <div class="flex gap-6 overflow-x-auto no-scrollbar snap-x snap-mandatory py-4 px-1 scroll-smooth">
      
      <!-- Category 1: Outdoors -->
      <a href="#destinasi" class="w-[180px] sm:w-[220px] shrink-0 snap-start group text-center block">
        <div class="aspect-square rounded-2xl overflow-hidden border border-border-color shadow-sm bg-slate-100 mb-3.5 transition-all duration-300 group-hover:shadow-md group-hover:-translate-y-1">
          <img class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-103" src="/images/outdoors_interest.png" alt="Petualangan Alam Banyuwangi" loading="lazy" />
        </div>
        <span class="text-sm font-black text-text-main tracking-tight group-hover:text-primary transition-colors flex items-center justify-center gap-1">
          Petualangan Alam
          <ChevronRight class="w-3.5 h-3.5 opacity-0 group-hover:opacity-100 transition-all shrink-0" />
        </span>
      </a>

      <!-- Category 2: Beaches -->
      <a href="#destinasi" class="w-[180px] sm:w-[220px] shrink-0 snap-start group text-center block">
        <div class="aspect-square rounded-2xl overflow-hidden border border-border-color shadow-sm bg-slate-100 mb-3.5 transition-all duration-300 group-hover:shadow-md group-hover:-translate-y-1">
          <img class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-103" src="/images/beaches_interest.png" alt="Pantai & Surfing Banyuwangi" loading="lazy" />
        </div>
        <span class="text-sm font-black text-text-main tracking-tight group-hover:text-primary transition-colors flex items-center justify-center gap-1">
          Pantai & Surfing
          <ChevronRight class="w-3.5 h-3.5 opacity-0 group-hover:opacity-100 transition-all shrink-0" />
        </span>
      </a>

      <!-- Category 3: Culture -->
      <a href="#budaya" class="w-[180px] sm:w-[220px] shrink-0 snap-start group text-center block">
        <div class="aspect-square rounded-2xl overflow-hidden border border-border-color shadow-sm bg-slate-100 mb-3.5 transition-all duration-300 group-hover:shadow-md group-hover:-translate-y-1">
          <img class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-103" src="/images/cultural_interest.png" alt="Seni & Budaya Osing" loading="lazy" />
        </div>
        <span class="text-sm font-black text-text-main tracking-tight group-hover:text-primary transition-colors flex items-center justify-center gap-1">
          Seni & Budaya
          <ChevronRight class="w-3.5 h-3.5 opacity-0 group-hover:opacity-100 transition-all shrink-0" />
        </span>
      </a>

      <!-- Category 4: Wildlife Safari -->
      <a href="#destinasi" class="w-[180px] sm:w-[220px] shrink-0 snap-start group text-center block">
        <div class="aspect-square rounded-2xl overflow-hidden border border-border-color shadow-sm bg-slate-100 mb-3.5 transition-all duration-300 group-hover:shadow-md group-hover:-translate-y-1">
          <img class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-103" src="/images/wildlife_interest.png" alt="Margasatwa & Safari Baluran" loading="lazy" />
        </div>
        <span class="text-sm font-black text-text-main tracking-tight group-hover:text-primary transition-colors flex items-center justify-center gap-1">
          Margasatwa & Safari
          <ChevronRight class="w-3.5 h-3.5 opacity-0 group-hover:opacity-100 transition-all shrink-0" />
        </span>
      </a>

      <!-- Category 5: Food & Coffee -->
      <a href="#budaya" class="w-[180px] sm:w-[220px] shrink-0 snap-start group text-center block">
        <div class="aspect-square rounded-2xl overflow-hidden border border-border-color shadow-sm bg-slate-100 mb-3.5 transition-all duration-300 group-hover:shadow-md group-hover:-translate-y-1">
          <img class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-103" src="/images/culinary_interest.png" alt="Kuliner Khas Banyuwangi" loading="lazy" />
        </div>
        <span class="text-sm font-black text-text-main tracking-tight group-hover:text-primary transition-colors flex items-center justify-center gap-1">
          Kuliner Khas Osing
          <ChevronRight class="w-3.5 h-3.5 opacity-0 group-hover:opacity-100 transition-all shrink-0" />
        </span>
      </a>

    </div>
  </div>
</section>

<!-- Hide Scrollbar Utility -->
<style>
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
