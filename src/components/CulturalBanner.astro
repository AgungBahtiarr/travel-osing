---
// CulturalBanner Component
// TripAdvisor-style clean magazine grid spread for cultural highlights.
import { Sparkles, ArrowRight } from '@lucide/astro';
import { Image } from 'astro:assets';
import { useTranslations } from '../utils/i18n';

const locale = Astro.currentLocale || 'id';
const t = useTranslations(locale);
---

<section class="py-20 px-6 bg-white" id="budaya">
  <div class="max-w-7xl mx-auto px-6 relative">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      
      <!-- Left Column: Image Spread with TripAdvisor borders -->
      <div class="relative rounded-2xl overflow-hidden border border-border-color shadow-sm h-[360px] md:h-[450px] shrink-0">
        <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent z-10"></div>
        <Image class="w-full h-full object-cover object-[center_40%] grayscale-[5%]" src="/images/kemiren.png" alt="Wisata Tradisional Desa Adat Kemiren Banyuwangi" width={800} height={500} loading="lazy" />
        
        <!-- Image overlay tagline -->
        <div class="absolute bottom-6 left-6 z-20 text-white text-left select-none">
          <span class="text-[0.65rem] font-extrabold uppercase tracking-wider bg-white/20 backdrop-blur-xs px-2.5 py-1 rounded">Desa Kemiren</span>
          <h4 class="text-xl font-bold mt-1 tracking-tight">{locale === 'en' ? 'Authentic Osing Heritage' : 'Otentisitas Suku Adat Osing'}</h4>
        </div>
      </div>

      <!-- Right Column: Clean Editorial Content -->
      <div class="text-left space-y-6 lg:pl-6">
        <div class="inline-flex items-center gap-1 bg-accent-light text-accent-hover px-3.5 py-1.5 rounded-full font-bold text-[0.75rem] uppercase tracking-wider shadow-sm select-none">
          <Sparkles class="w-3.5 h-3.5 shrink-0" />
          {t('cultural.badge')}
        </div>
        
        <h2 class="font-sans text-3xl md:text-4xl text-text-main font-black tracking-tight leading-tight">
          {t('cultural.title')}
        </h2>
        
        <p class="text-text-muted text-base leading-relaxed font-medium">
          {t('cultural.subtitle')}
        </p>

        <div class="pt-2">
          <a 
            href="#rencana" 
            class="inline-flex items-center gap-2 bg-text-main hover:bg-text-muted text-white font-extrabold text-xs tracking-wider uppercase px-7 py-4 rounded-full shadow-sm transition-all duration-150 group" 
            id="banner-pkg-btn"
          >
            <span>{locale === 'en' ? 'Explore Cultural Packages' : 'Lihat Paket Budaya'}</span>
            <ArrowRight class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-1 shrink-0" />
          </a>
        </div>
      </div>

    </div>
  </div>
</section>
