---
// Footer Component
import { useTranslations } from '../utils/i18n';

const locale = Astro.currentLocale || 'id';
const t = useTranslations(locale);
const prefix = locale === 'en' ? '/en' : '';
---

<footer class="bg-bg-dark text-[#cbd5e1] py-20 px-6 text-[0.95rem] relative overflow-hidden before:content-[''] before:absolute before:bottom-0 before:right-0 before:w-[400px] before:h-[400px] before:bg-[radial-gradient(circle,rgba(54,167,226,0.05)_0%,transparent_70%)] before:pointer-events-none" id="kontak">
  <div class="max-w-7xl mx-auto px-6 relative">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-[1.2fr_0.8fr_0.8fr_1.2fr] gap-10 lg:gap-12 mb-15">
      <!-- Column 1: Brand and Bio -->
      <div class="text-left">
        <a href={prefix === '' ? '/' : prefix} class="font-serif text-[1.85rem] font-extrabold text-white mb-5 flex items-center gap-1.5">
          Travel<span class="text-primary">Osing</span><span class="text-accent text-[2.2rem] leading-none -ml-0.5">.</span>
        </a>
        <p class="text-[#94a3b8] leading-relaxed mb-6 max-w-[320px]">
          {t('footer.desc')}
        </p>
        <div class="flex gap-4">
          <a href="#" class="w-10 h-10 rounded-full bg-white/5 text-white flex items-center justify-center transition-all hover:bg-primary hover:-translate-y-0.75" aria-label="Facebook">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
          </a>
          <a href="#" class="w-10 h-10 rounded-full bg-white/5 text-white flex items-center justify-center transition-all hover:bg-primary hover:-translate-y-0.75" aria-label="Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
          </a>
          <a href="#" class="w-10 h-10 rounded-full bg-white/5 text-white flex items-center justify-center transition-all hover:bg-primary hover:-translate-y-0.75" aria-label="Twitter">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"></path></svg>
          </a>
        </div>
      </div>

      <!-- Column 2: Quick Links -->
      <div class="text-left">
        <h3 class="font-sans text-[1.1rem] font-bold text-white mb-6 relative pb-2.5 after:content-[''] after:absolute after:bottom-0 after:left-0 after:w-[30px] after:h-0.5 after:bg-primary">{t('footer.links.explore')}</h3>
        <ul class="list-none flex flex-col gap-3.5">
          <li><a href={`${prefix}/`} class="text-[#94a3b8] transition-all hover:text-white hover:pl-1.5">{t('nav.home')}</a></li>
          <li><a href={`${prefix}/#destinasi`} class="text-[#94a3b8] transition-all hover:text-white hover:pl-1.5">{t('nav.destinations')}</a></li>
          <li><a href={`${prefix}/#kalender-event`} class="text-[#94a3b8] transition-all hover:text-white hover:pl-1.5">{t('nav.festivals')}</a></li>
          <li><a href={`${prefix}/#budaya`} class="text-[#94a3b8] transition-all hover:text-white hover:pl-1.5">{t('nav.culture')}</a></li>
          <li><a href={`${prefix}/blog`} class="text-[#94a3b8] transition-all hover:text-white hover:pl-1.5">{t('nav.blog')}</a></li>
        </ul>
      </div>

      <!-- Column 3: Destination Links -->
      <div class="text-left">
        <h3 class="font-sans text-[1.1rem] font-bold text-white mb-6 relative pb-2.5 after:content-[''] after:absolute after:bottom-0 after:left-0 after:w-[30px] after:h-0.5 after:bg-primary">{t('footer.links.company')}</h3>
        <ul class="list-none flex flex-col gap-3.5">
          <li><a href={`${prefix}/#destinasi`} class="text-[#94a3b8] transition-all hover:text-white hover:pl-1.5">Kawah Ijen Midnight</a></li>
          <li><a href={`${prefix}/#destinasi`} class="text-[#94a3b8] transition-all hover:text-white hover:pl-1.5">Baluran Africa Safari</a></li>
          <li><a href={`${prefix}/#destinasi`} class="text-[#94a3b8] transition-all hover:text-white hover:pl-1.5">Surfing Pulau Merah</a></li>
          <li><a href={`${prefix}/#budaya`} class="text-[#94a3b8] transition-all hover:text-white hover:pl-1.5">Adat Desa Kemiren</a></li>
        </ul>
      </div>

      <!-- Column 4: Newsletter & Contact Info -->
      <div class="text-left">
        <h3 class="font-sans text-[1.1rem] font-bold text-white mb-6 relative pb-2.5 after:content-[''] after:absolute after:bottom-0 after:left-0 after:w-[30px] after:h-0.5 after:bg-primary">{t('footer.links.contact')}</h3>
        <p class="text-[#94a3b8] mb-4.5">{locale === 'en' ? 'Get interesting travel discounts right in your inbox.' : 'Dapatkan diskon paket perjalanan menarik langsung di inbox email Anda.'}</p>
        
        <!-- Newsletter Form -->
        <form class="flex flex-col gap-2.5" onsubmit="event.preventDefault(); alert('Thank you! You have successfully subscribed to our newsletter.');">
          <div class="relative w-full">
            <input type="email" placeholder={locale === 'en' ? "Enter email address" : "Masukkan alamat email"} class="w-full bg-white/5 border border-white/10 px-5 py-3.5 rounded-2xl text-white text-[0.9rem] transition-all focus:border-primary focus:bg-white/8 outline-none" required id="newsletter-email-input" />
          </div>
          <button type="submit" class="bg-primary text-white font-bold text-[0.95rem] px-6 py-3.5 rounded-2xl cursor-pointer transition-all shadow-[0_4px_14px_rgba(54,167,226,0.2)] text-center hover:bg-primary-hover hover:-translate-y-0.5 hover:shadow-[0_6px_20px_rgba(54,167,226,0.3)]" id="newsletter-submit-btn">{locale === 'en' ? 'Subscribe' : 'Berlangganan'}</button>
        </form>

        <div class="flex flex-col gap-4 mt-6">
          <div class="flex gap-3 items-start text-left">
            <svg class="text-primary mt-[3px] shrink-0" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
            <p class="text-[#94a3b8] leading-normal">Jl. Adat Kemiren No. 12, Kecamatan Glagah, Kabupaten Banyuwangi, Jawa Timur, 68432</p>
          </div>
          
          <div class="flex gap-3 items-start text-left">
            <svg class="text-primary mt-[3px] shrink-0" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            <p class="text-[#94a3b8] leading-normal">+62 812-3456-7890</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Copyright Bar -->
    <div class="border-t border-white/5 pt-7.5 flex flex-col md:flex-row items-center justify-between text-[#64748b] text-[0.85rem] gap-4 text-center md:text-left">
      <p>&copy; 2026 Travel Osing. {locale === 'en' ? 'All Rights Reserved.' : 'Seluruh Hak Cipta Dilindungi Undang-Undang.'}</p>
      <div class="flex gap-5">
        <a href="#" class="hover:text-white transition-colors">{locale === 'en' ? 'Privacy Policy' : 'Kebijakan Privasi'}</a>
        <a href="#" class="hover:text-white transition-colors">{locale === 'en' ? 'Terms & Conditions' : 'Syarat & Ketentuan'}</a>
      </div>
    </div>
  </div>
</footer>
