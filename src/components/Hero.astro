---
// Hero Component
// TripAdvisor-style extremely clean hero section with built-in search planner bar.
import { Sun, Search, MapPin, Calendar } from '@lucide/astro';
import { Image } from 'astro:assets';
import { useTranslations } from '../utils/i18n';

const locale = Astro.currentLocale;
const t = useTranslations(locale);
const prefix = locale === 'en' ? '/en' : '';
---

<section class="py-16 md:py-24 bg-white border-b border-border-color overflow-hidden" id="beranda">
  <div class="max-w-7xl mx-auto px-6 relative">
    <div class="grid grid-cols-1 lg:grid-cols-[1.1fr_0.9fr] gap-12 lg:gap-16 items-center">
      
      <!-- Text & Search Section -->
      <div class="text-center lg:text-left">
        <div class="inline-flex items-center gap-1.5 bg-accent-light text-accent-hover px-4 py-1.5 rounded-full font-bold text-xs tracking-wider mb-6 uppercase shadow-sm">
          <Sun class="w-3.5 h-3.5 shrink-0" />
          {t('hero.badge')}
        </div>
        
        <h1 class="font-sans text-4xl md:text-[3.5rem] leading-[1.15] text-text-main mb-6 font-black tracking-tight">
          {t('hero.title.1')} <span class="text-primary">{t('hero.title.2')}</span>
        </h1>
        
        <p class="text-text-muted text-base md:text-lg leading-relaxed mb-10 max-w-[560px] mx-auto lg:mx-0 font-medium">
          {t('hero.subtitle')}
        </p>

        <!-- TripAdvisor-style Horizontal Search Bar -->
        <div class="bg-white p-2 md:p-3 rounded-2xl md:rounded-full border border-border-color shadow-lg max-w-[620px] mx-auto lg:mx-0 flex flex-col sm:flex-row items-stretch sm:items-center gap-2">
          <!-- Destinasi Dropdown panel -->
          <div class="flex-1 px-4 py-2 border-b sm:border-b-0 sm:border-r border-border-color flex items-center gap-3 text-left">
            <MapPin class="w-5 h-5 text-text-light shrink-0" />
            <div>
              <span class="text-[0.65rem] text-text-light block font-extrabold uppercase tracking-wider">{t('hero.search.dest')}</span>
              <span class="text-xs font-bold text-text-main">{t('hero.search.dest.placeholder')}</span>
            </div>
          </div>
          
          <!-- Durasi panel -->
          <div class="px-4 py-2 border-b sm:border-b-0 sm:border-r border-border-color flex items-center gap-3 text-left">
            <Calendar class="w-5 h-5 text-text-light shrink-0" />
            <div>
              <span class="text-[0.65rem] text-text-light block font-extrabold uppercase tracking-wider">{t('hero.search.date')}</span>
              <span class="text-xs font-bold text-text-main">{t('hero.search.date.placeholder')}</span>
            </div>
          </div>

          <!-- CTA Search Button -->
          <a 
            href="#rencana" 
            class="bg-text-main hover:bg-text-muted text-white px-6 py-4 sm:py-3.5 rounded-xl sm:rounded-full font-bold text-sm tracking-wide transition-all flex items-center justify-center gap-2 cursor-pointer shadow-sm shrink-0"
          >
            <Search class="w-4 h-4 shrink-0" />
            <span>{t('hero.search.btn')}</span>
          </a>
        </div>
      </div>

      <!-- Clean Overlapping Composition (Minimalist, TripAdvisor-like borders) -->
      <div class="relative h-[380px] md:h-[450px] lg:h-[480px] w-full max-w-[480px] lg:max-w-none mx-auto flex items-center justify-center group">
        <!-- Base Background Card (Ijen) -->
        <div class="absolute top-0 left-0 w-[84%] h-[84%] rounded-3xl overflow-hidden shadow-overlap-bg border border-border-color bg-white z-10 transition-all duration-300 group-hover:-translate-y-1">
          <Image class="w-full h-full object-cover grayscale-[10%] group-hover:scale-102 transition-transform duration-700" src="/images/hero_bg.png" alt="Danau Kawah Ijen Banyuwangi" width={600} height={500} loading="eager" />
        </div>
        
        <!-- Overlapping Card (Traveler) -->
        <div class="absolute bottom-0 right-0 w-[56%] h-[76%] rounded-3xl overflow-hidden shadow-overlap-fg border-4 border-white z-20 transition-all duration-300 group-hover:-translate-y-2">
          <Image class="w-full h-full object-cover grayscale-[10%] group-hover:scale-102 transition-transform duration-700" src="/images/traveler.png" alt="Wisatawan Banyuwangi" width={400} height={500} loading="eager" />
        </div>

        <!-- Float Badge 1 (Clean pill) -->
        <div class="absolute top-[8%] -right-[3%] bg-white border border-border-color px-4.5 py-2.5 rounded-full shadow-md z-30 flex items-center gap-2 animate-float">
          <span class="w-2.5 h-2.5 rounded-full bg-accent animate-pulse shrink-0"></span>
          <span class="text-xs font-extrabold text-text-main">Local Osing Guides</span>
        </div>
      </div>

    </div>
  </div>
</section>
