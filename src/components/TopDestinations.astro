---
// TopDestinations Component
// TripAdvisor-style premium horizontal carousel for travel destinations using Content Collections.
import { getCollection } from 'astro:content';
import { Heart, ChevronLeft, ChevronRight } from '@lucide/astro';
import { Image } from 'astro:assets';
import { useTranslations } from '../utils/i18n';

const locale = Astro.currentLocale || 'id';
const t = useTranslations(locale);

const destinations = await getCollection('destinations');
// Filter based on locale folder prefix
const filteredDestinations = destinations.filter(item => item.id.startsWith(`${locale}/`));
const sortedDestinations = filteredDestinations.sort((a, b) => a.data.sortOrder - b.data.sortOrder);
---

<section class="py-20 px-6 bg-white overflow-hidden" id="destinasi">
  <div class="max-w-7xl mx-auto px-6 relative">
    
    <!-- TripAdvisor-style Premium Section Header with Carousel Navigation on Right -->
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-10 gap-6">
      <div class="text-left max-w-[580px]">
        <span class="inline-block text-[0.75rem] font-bold uppercase tracking-[0.2em] text-primary mb-2.5">
          {t('dest.badge')}
        </span>
        <h2 class="font-sans text-3xl md:text-4xl text-text-main font-black tracking-tight leading-tight">
          {t('dest.title')}
        </h2>
      </div>
      
      <!-- Navigation buttons placed in the header row for modern premium look -->
      <div class="flex items-center gap-2.5 shrink-0 self-start md:self-end">
        <button 
          type="button" 
          id="carousel-prev" 
          class="w-11 h-11 rounded-full border border-border-color bg-white hover:bg-slate-50 flex items-center justify-center text-text-main transition-all cursor-pointer focus:outline-none disabled:opacity-40 disabled:cursor-not-allowed"
          aria-label="Previous slide"
        >
          <ChevronLeft class="w-5 h-5 shrink-0" />
        </button>
        <button 
          type="button" 
          id="carousel-next" 
          class="w-11 h-11 rounded-full border border-border-color bg-white hover:bg-slate-50 flex items-center justify-center text-text-main transition-all cursor-pointer focus:outline-none disabled:opacity-40 disabled:cursor-not-allowed"
          aria-label="Next slide"
        >
          <ChevronRight class="w-5 h-5 shrink-0" />
        </button>
      </div>
    </div>

    <!-- Horizontal Scrollable Row (Clean Aspect Ratio Cards) -->
    <div 
      id="destinations-carousel" 
      class="flex items-stretch gap-6 overflow-x-auto no-scrollbar snap-x snap-mandatory py-4 px-1 scroll-smooth"
    >
      
      {sortedDestinations.map((dest) => (
        <article class="carousel-card w-[280px] sm:w-[320px] shrink-0 snap-start bg-white rounded-2xl overflow-hidden border border-border-color shadow-sm hover:shadow-md transition-all duration-300 flex flex-col h-[465px] sm:h-[495px] group">
          <div class="relative w-full h-[200px] sm:h-[230px] overflow-hidden bg-slate-100 border-b border-border-color">
            <!-- TripAdvisor-style heart save button -->
            <button 
              type="button" 
              class="save-btn absolute top-4 right-4 w-9 h-9 rounded-full bg-white/90 hover:bg-white backdrop-blur-sm border border-border-color/60 flex items-center justify-center text-text-muted hover:text-red-500 transition-all shadow-sm z-10 cursor-pointer focus:outline-none active:scale-90"
              aria-label="Simpan destinasi"
            >
              <Heart class="w-4 h-4 shrink-0 transition-colors" />
            </button>
            
            <span class="absolute top-4 left-4 bg-text-main/90 backdrop-blur-md text-white px-3 py-1 rounded-lg font-bold text-[0.65rem] uppercase tracking-wider shadow-sm z-10 select-none">
              {dest.data.category}
            </span>
            <Image class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-103" src={dest.data.image} alt={locale === 'en' ? `Landscape: ${dest.data.title}` : `Pemandangan: ${dest.data.title}`} width={400} height={300} loading="lazy" />
          </div>
          <div class="p-6 flex flex-col flex-grow text-left">
            <h3 class="text-lg font-black text-text-main mb-1 tracking-tight group-hover:text-primary transition-colors cursor-pointer leading-snug">
              {dest.data.title}
            </h3>
            
            <!-- TripAdvisor Bubble Rating -->
            <div class="flex items-center gap-2 mb-3">
              <div class="flex gap-0.5">
                {Array.from({ length: 5 }).map((_, i) => (
                  <span class={`w-2.5 h-2.5 rounded-full inline-block ${i < Math.round(dest.data.rating) ? 'bg-[#00aa6c]' : 'bg-[#00aa6c]/20 border border-[#00aa6c]/10'}`}></span>
                ))}
              </div>
              <span class="text-xs font-semibold text-text-light">{dest.data.rating} ({dest.data.reviewsCount} {t('dest.rating.reviews')})</span>
            </div>

            <p class="text-text-muted text-xs md:text-[0.825rem] leading-relaxed mb-6 flex-grow font-medium line-clamp-3">
              {dest.data.description}
            </p>
            
            <div class="flex items-center justify-between pt-4 border-t border-border-color mt-auto">
              <div class="flex flex-col">
                <span class="text-[0.65rem] text-text-light uppercase font-bold tracking-wider mb-0.5">{t('dest.price.from')}</span>
                <span class="text-base font-black text-text-main">
                  Rp {dest.data.price.toLocaleString('id-ID')} <small class="text-[0.65rem] text-text-light font-normal">/{dest.data.priceUnit === 'pax' ? t('dest.price.unit') : dest.data.priceUnit}</small>
                </span>
              </div>
              
              <a 
                href={locale === 'en' 
                  ? `/en/destinations/${dest.id.replace(/^en\//, '')}` 
                  : `/destinasi/${dest.id.replace(/^id\//, '')}`}
                class="inline-flex items-center gap-1.5 bg-primary-light text-primary hover:bg-primary hover:text-white font-extrabold text-[0.7rem] uppercase tracking-wider px-4 py-2.5 rounded-full transition-all cursor-pointer"
              >
                {t('dest.btn.explore')}
              </a>
            </div>
          </div>
        </article>
      ))}

    </div>
  </div>
</section>

<!-- Hide Scrollbar Styles -->
<style>
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>

<!-- Carousel Script Interactivity -->
<script>
  const track = document.getElementById('destinations-carousel');
  const prevBtn = document.getElementById('carousel-prev');
  const nextBtn = document.getElementById('carousel-next');

  if (track && prevBtn && nextBtn) {
    const getScrollAmount = () => {
      const firstCard = track.querySelector('.carousel-card') as HTMLElement;
      return firstCard ? firstCard.offsetWidth + 24 : 320; // 24 is gap-6
    };

    nextBtn.addEventListener('click', () => {
      track.scrollBy({ left: getScrollAmount(), behavior: 'smooth' });
    });

    prevBtn.addEventListener('click', () => {
      track.scrollBy({ left: -getScrollAmount(), behavior: 'smooth' });
    });

    // Handle button disable states based on scroll position
    const updateButtons = () => {
      const scrollLeft = track.scrollLeft;
      const maxScroll = track.scrollWidth - track.clientWidth;
      
      (prevBtn as HTMLButtonElement).disabled = scrollLeft <= 8;
      (nextBtn as HTMLButtonElement).disabled = scrollLeft >= maxScroll - 8;
    };

    track.addEventListener('scroll', updateButtons);
    
    // Check initial state after load
    setTimeout(updateButtons, 100);
    window.addEventListener('resize', updateButtons);
  }
</script>
