---
// Navbar Component
// TripAdvisor-style super clean minimalist navbar.
import { useTranslations } from '../utils/i18n';

const locale = Astro.currentLocale;
const t = useTranslations(locale);
const prefix = locale === 'en' ? '/en' : '';
const currentPath = Astro.url.pathname;

// Switch path helper
let targetLangPath = '';
if (locale === 'en') {
  targetLangPath = currentPath.startsWith('/en') ? currentPath.replace(/^\/en/, '') : '/';
  if (targetLangPath === '') targetLangPath = '/';
} else {
  targetLangPath = `/en${currentPath === '/' ? '' : currentPath}`;
}
---

<header class="sticky top-0 left-0 w-full z-[100] bg-white border-b border-border-color transition-all duration-200">
  <div class="max-w-7xl mx-auto px-6 relative flex items-center justify-between h-20">
    <!-- Clean Off-Black Logo -->
    <a href={prefix === '' ? '/' : prefix} class="font-sans text-[1.4rem] font-black text-text-main flex items-center gap-1.5 tracking-tight" id="main-logo">
      Travel<span class="text-primary font-black">Osing</span><span class="text-accent text-2xl leading-none -ml-0.5 font-black">.</span>
    </a>
    
    <!-- Clean Flat Menu -->
    <ul class="nav-menu hidden md:flex list-none gap-2 font-bold text-sm text-text-muted">
      <li>
        <a href={`${prefix}/`} class="hover:text-text-main hover:bg-slate-50 px-4 py-2.5 rounded-full transition-all duration-150">
          {t('nav.home')}
        </a>
      </li>
      <li>
        <a href={`${prefix}/#destinasi`} class="hover:text-text-main hover:bg-slate-50 px-4 py-2.5 rounded-full transition-all duration-150">
          {t('nav.destinations')}
        </a>
      </li>
      <li>
        <a href={`${prefix}/#kalender-event`} class="hover:text-text-main hover:bg-slate-50 px-4 py-2.5 rounded-full transition-all duration-150">
          {t('nav.festivals')}
        </a>
      </li>
      <li>
        <a href={`${prefix}/#budaya`} class="hover:text-text-main hover:bg-slate-50 px-4 py-2.5 rounded-full transition-all duration-150">
          {t('nav.culture')}
        </a>
      </li>
      <li>
        <a href={`${prefix}/#testimoni`} class="hover:text-text-main hover:bg-slate-50 px-4 py-2.5 rounded-full transition-all duration-150">
          Testimoni
        </a>
      </li>
      <li>
        <a href={`${prefix}/blog`} class="hover:text-text-main hover:bg-slate-50 px-4 py-2.5 rounded-full transition-all duration-150">
          {t('nav.blog')}
        </a>
      </li>
      <li>
        <a href={`${prefix}/#faq`} class="hover:text-text-main hover:bg-slate-50 px-4 py-2.5 rounded-full transition-all duration-150">
          {t('nav.faq')}
        </a>
      </li>
      
      <!-- Mobile Language Switcher link inside menu -->
      <li class="md:hidden pt-4 border-t border-border-color mt-2 flex justify-center">
        <a 
          href={targetLangPath} 
          class="flex items-center gap-2 px-4 py-2 rounded-full border border-border-color bg-slate-50 text-xs font-bold uppercase tracking-wider text-text-main"
        >
          <span>Language:</span>
          <span class={locale === 'id' || !locale ? "text-primary font-black" : "text-text-light"}>ID</span>
          <span class="text-text-light">/</span>
          <span class={locale === 'en' ? "text-primary font-black" : "text-text-light"}>EN</span>
        </a>
      </li>
    </ul>

    <!-- Pill-shaped Clean CTA & Language Switcher -->
    <div class="hidden md:flex items-center gap-3">
      <!-- Language Switcher -->
      <a 
        href={targetLangPath}
        class="flex items-center gap-1.5 px-3.5 py-2.5 rounded-full border border-border-color hover:bg-slate-50 text-xs font-extrabold tracking-wide uppercase transition-all duration-150 text-text-muted hover:text-text-main shrink-0"
        title={locale === 'en' ? "Switch to Indonesian" : "Ubah ke Bahasa Inggris"}
      >
        <span class={locale === 'id' || !locale ? "text-primary font-black" : "text-text-light font-medium"}>ID</span>
        <span class="text-text-light">/</span>
        <span class={locale === 'en' ? "text-primary font-black" : "text-text-light font-medium"}>EN</span>
      </a>

      <a href="#kontak" class="bg-text-main text-white hover:bg-text-muted px-6 py-3 rounded-full text-xs font-extrabold tracking-wide uppercase transition-all duration-150 shadow-sm whitespace-nowrap" id="nav-cta-btn">
        {t('nav.contact')}
      </a>
    </div>

    <!-- Mobile Burger Toggle -->
    <div class="flex md:hidden flex-col gap-1 cursor-pointer p-2 hover:bg-slate-50 rounded-full transition-all" id="mobile-menu-toggle" aria-label="Menu navigasi">
      <span class="block w-[20px] h-[2px] bg-text-main rounded-sm transition-all"></span>
      <span class="block w-[20px] h-[2px] bg-text-main rounded-sm transition-all"></span>
      <span class="block w-[20px] h-[2px] bg-text-main rounded-sm transition-all"></span>
    </div>
  </div>
</header>

<!-- Simple responsive mobile menu helper -->
<script>
  const menuToggle = document.getElementById('mobile-menu-toggle');
  const navMenu = document.querySelector('.nav-menu');

  if (menuToggle && navMenu) {
    menuToggle.addEventListener('click', () => {
      const isMobileOpen = navMenu.classList.contains('flex') && !navMenu.classList.contains('hidden');
      
      if (isMobileOpen) {
        navMenu.classList.add('hidden');
        navMenu.classList.remove('flex', 'flex-col', 'absolute', 'top-20', 'left-0', 'w-full', 'bg-white', 'p-6', 'border-b', 'border-border-color', 'z-[99]', 'gap-3', 'items-stretch', 'shadow-md');
      } else {
        navMenu.classList.remove('hidden');
        navMenu.classList.add('flex', 'flex-col', 'absolute', 'top-20', 'left-0', 'w-full', 'bg-white', 'p-6', 'border-b', 'border-border-color', 'z-[99]', 'gap-3', 'items-stretch', 'shadow-md');
      }
    });

    window.addEventListener('resize', () => {
      if (window.innerWidth > 768) {
        navMenu.classList.remove('flex', 'flex-col', 'absolute', 'top-20', 'left-0', 'w-full', 'bg-white', 'p-6', 'border-b', 'border-border-color', 'z-[99]', 'gap-3', 'items-stretch', 'shadow-md');
        navMenu.classList.add('hidden');
      }
    });
  }
</script>
