---
// WhatsAppWidget Component
// Premium floating WhatsApp chat assistant widget.
import { Flame, Compass, Sunset, Sparkles, X, ChevronRight } from '@lucide/astro';
import { Image } from 'astro:assets';
import { useTranslations } from '../utils/i18n';

const locale = Astro.currentLocale || 'id';
const t = useTranslations(locale);
---

<div class="fixed bottom-6 right-6 z-[999] flex flex-col items-end select-none">
  <!-- Chat Popup Window -->
  <div 
    id="wa-popup-window" 
    class="hidden w-[350px] max-w-[calc(100vw-48px)] bg-white/95 backdrop-blur-md rounded-3xl shadow-[0_20px_50px_rgba(15,23,42,0.15)] border border-slate-100 overflow-hidden mb-4 transition-all duration-300 transform translate-y-4 scale-95 origin-bottom-right"
  >
    <!-- Window Header -->
    <div class="bg-primary p-6 text-white flex items-center justify-between">
      <div class="flex items-center gap-3 text-left">
        <div class="w-12 h-12 rounded-full overflow-hidden border-2 border-white/30 shrink-0 relative">
          <Image class="w-full h-full object-cover" src="/images/avatar1.png" alt="Admin Travel Osing" width={48} height={48} />
          <span class="absolute bottom-0 right-0 w-3 h-3 bg-green-500 rounded-full border-2 border-primary animate-pulse"></span>
        </div>
        <div>
          <h4 class="font-extrabold text-base leading-tight">Mila</h4>
          <p class="text-xs text-white/80 font-medium">Customer Relation Travel Osing</p>
        </div>
      </div>
      <button 
        type="button" 
        id="wa-close-btn" 
        class="text-white/80 hover:text-white hover:bg-white/10 p-1.5 rounded-full transition-colors cursor-pointer focus:outline-none flex items-center justify-center"
        aria-label={locale === 'en' ? 'Close chat assistant' : 'Tutup asisten chat'}
      >
        <X class="w-5 h-5" />
      </button>
    </div>

    <!-- Window Body (Chat Messages) -->
    <div class="p-6 bg-bg-secondary text-left space-y-4 max-h-[300px] overflow-y-auto">
      <div class="bg-white p-4.5 rounded-2xl rounded-tl-sm shadow-sm border border-slate-100/50 text-sm leading-relaxed text-text-muted">
        <p class="font-bold text-text-main mb-1 text-xs uppercase tracking-wider text-primary">Travel Osing Bot</p>
        {locale === 'en' 
          ? 'Hello! Welcome to Banyuwangi. Is there anything Mila can help you with to plan your premium adventure? Please select a topic below:' 
          : 'Halo! Selamat datang di Banyuwangi. Ada yang bisa Mila bantu untuk merencanakan petualangan mewah Anda? Silakan pilih topik tanya di bawah ini:'}
      </div>
    </div>

    <!-- Quick Actions List -->
    <div class="p-5 bg-white border-t border-slate-100 space-y-2 flex flex-col">
      <a 
        href={locale === 'en' 
          ? "https://wa.me/6281234567890?text=Hello%20Mila!%20I%20am%20interested%20in%20the%20Mount%20Ijen%20Midnight%20(Blue%20Fire)%20Tour%20Package.%20Could%20I%20get%20more%20information?"
          : "https://wa.me/6281234567890?text=Halo%20Mila!%20Saya%20tertarik%20dengan%20Paket%20Kawah%20Ijen%20Midnight%20(Blue%20Fire).%20Boleh%20minta%20info%20ketersediaan%20slotnya?"} 
        target="_blank"
        class="wa-quick-action w-full text-left py-2.5 px-4 rounded-xl bg-bg-secondary text-text-main text-xs font-bold border border-slate-100 hover:border-primary/30 hover:bg-primary-light hover:text-primary transition-all flex items-center justify-between"
      >
        <span class="flex items-center gap-2">
          <Flame class="w-4 h-4 text-primary shrink-0" />
          {locale === 'en' ? 'Mount Ijen Midnight Tour' : 'Paket Kawah Ijen Midnight'}
        </span>
        <ChevronRight class="w-3.5 h-3.5 text-text-light shrink-0" />
      </a>
      <a 
        href={locale === 'en'
          ? "https://wa.me/6281234567890?text=Hello%20Mila!%20I%20am%20interested%20in%20the%20Baluran%20National%20Park%20Safari.%20Could%20I%20get%20more%20information?"
          : "https://wa.me/6281234567890?text=Halo%20Mila!%20Saya%20tertarik%20dengan%20Paket%20Safari%20Taman%20Nasional%20Baluran.%20Bisa%20minta%20info%20detailnya?"} 
        target="_blank"
        class="wa-quick-action w-full text-left py-2.5 px-4 rounded-xl bg-bg-secondary text-text-main text-xs font-bold border border-slate-100 hover:border-primary/30 hover:bg-primary-light hover:text-primary transition-all flex items-center justify-between"
      >
        <span class="flex items-center gap-2">
          <Compass class="w-4 h-4 text-primary shrink-0" />
          {locale === 'en' ? 'Baluran Africa Safari Tour' : 'Paket Safari Baluran Africa'}
        </span>
        <ChevronRight class="w-3.5 h-3.5 text-text-light shrink-0" />
      </a>
      <a 
        href={locale === 'en'
          ? "https://wa.me/6281234567890?text=Hello%20Mila!%20I%20am%20interested%20in%20the%20Red%20Island%20Beach%20Surfing%20Package.%20Could%20I%20get%20more%20information?"
          : "https://wa.me/6281234567890?text=Halo%20Mila!%20Saya%20tertarik%20dengan%20Paket%20Surfing%20Pulau%20Merah.%20Boleh%20tanya-tanya?"} 
        target="_blank"
        class="wa-quick-action w-full text-left py-2.5 px-4 rounded-xl bg-bg-secondary text-text-main text-xs font-bold border border-slate-100 hover:border-primary/30 hover:bg-primary-light hover:text-primary transition-all flex items-center justify-between"
      >
        <span class="flex items-center gap-2">
          <Sunset class="w-4 h-4 text-primary shrink-0" />
          {locale === 'en' ? 'Red Island Beach Tour' : 'Paket Wisata Pantai Pulau Merah'}
        </span>
        <ChevronRight class="w-3.5 h-3.5 text-text-light shrink-0" />
      </a>
      <a 
        href="#rencana" 
        id="wa-kustom-trigger"
        class="w-full text-left py-2.5 px-4 rounded-xl bg-primary text-white text-xs font-bold shadow-[0_4px_10px_rgba(54,167,226,0.2)] hover:bg-primary-hover transition-all flex items-center justify-between cursor-pointer"
      >
        <span class="flex items-center gap-2">
          <Sparkles class="w-4 h-4 text-white shrink-0" />
          {locale === 'en' ? 'Design My Custom Itinerary' : 'Rancang Paket Kustom Saya'}
        </span>
        <ChevronRight class="w-3.5 h-3.5 text-white shrink-0" />
      </a>
    </div>
  </div>

  <!-- Floating Green Chat Button -->
  <button 
    type="button" 
    id="wa-widget-toggle" 
    class="w-16 h-16 rounded-full bg-[#25d366] text-white flex items-center justify-center shadow-[0_10px_30px_rgba(37,211,102,0.3)] transition-all duration-300 hover:scale-105 hover:shadow-[0_12px_36px_rgba(37,211,102,0.45)] focus:outline-none relative cursor-pointer"
    aria-label={locale === 'en' ? 'Contact us via WhatsApp' : 'Hubungi kami melalui WhatsApp'}
  >
    <!-- Notification Dot Badge -->
    <span class="absolute -top-1 -right-1 w-5 h-5 bg-accent text-white font-extrabold text-[0.65rem] rounded-full border-2 border-white flex items-center justify-center animate-bounce">1</span>
    
    <!-- WhatsApp Logo Icon -->
    <svg class="w-8 h-8 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
      <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.717-1.458L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.825 1.451 5.436 0 9.86-4.42 9.864-9.864.002-2.637-1.03-5.114-2.905-6.99C16.655 1.875 14.179 1.846 11.98 1.846c-5.439 0-9.865 4.423-9.869 9.867-.001 1.702.461 3.361 1.337 4.815L2.43 21.03l4.217-1.876zm11.086-7.5c-.27-.135-1.602-.791-1.85-.882-.25-.09-.432-.135-.612.135-.18.27-.697.882-.855 1.062-.157.18-.315.202-.585.067-.27-.135-1.14-.42-2.172-1.34-.803-.715-1.345-1.6-1.502-1.87-.158-.27-.017-.417.118-.552.122-.122.27-.315.405-.472.135-.158.18-.27.27-.45.09-.18.045-.337-.022-.472-.068-.135-.612-1.474-.838-2.016-.22-.53-.442-.457-.612-.466-.157-.008-.337-.01-.517-.01-.18 0-.472.067-.72.337-.247.27-.945.922-.945 2.25s.967 2.61 1.102 2.79c.135.18 1.902 2.904 4.6 4.07 2.698 1.166 2.698.778 3.193.733.495-.045 1.602-.656 1.827-1.288.225-.633.225-1.177.157-1.288-.067-.113-.247-.203-.517-.338z"/>
    </svg>
  </button>
</div>

<!-- Widget script functionality -->
<script>
  const widgetToggle = document.getElementById('wa-widget-toggle');
  const popupWindow = document.getElementById('wa-popup-window');
  const closeBtn = document.getElementById('wa-close-btn');
  const kustomTrigger = document.getElementById('wa-kustom-trigger');

  if (widgetToggle && popupWindow && closeBtn) {
    widgetToggle.addEventListener('click', (e) => {
      e.stopPropagation();
      toggleChat();
    });

    closeBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      closeChat();
    });

    // Close chat popup window when clicking outside
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (!popupWindow.contains(target) && !widgetToggle.contains(target)) {
        closeChat();
      }
    });

    // Close when clicking quick actions to allow link redirect
    document.querySelectorAll('.wa-quick-action').forEach(action => {
      action.addEventListener('click', () => {
        setTimeout(closeChat, 300);
      });
    });

    if (kustomTrigger) {
      kustomTrigger.addEventListener('click', (e) => {
        e.preventDefault();
        closeChat();
        
        // Smooth scroll to planner section
        const plannerSection = document.getElementById('rencana');
        if (plannerSection) {
          plannerSection.scrollIntoView({ behavior: 'smooth' });
        }
      });
    }
  }

  function toggleChat() {
    const isHidden = popupWindow?.classList.contains('hidden');
    if (isHidden) {
      openChat();
    } else {
      closeChat();
    }
  }

  function openChat() {
    if (popupWindow) {
      popupWindow.classList.remove('hidden');
      // Subtle delay to allow CSS transitions to trigger
      setTimeout(() => {
        popupWindow.classList.remove('translate-y-4', 'scale-95', 'opacity-0');
        popupWindow.classList.add('translate-y-0', 'scale-100', 'opacity-100');
      }, 50);
    }
  }

  function closeChat() {
    if (popupWindow) {
      popupWindow.classList.remove('translate-y-0', 'scale-100', 'opacity-100');
      popupWindow.classList.add('translate-y-4', 'scale-95', 'opacity-0');
      setTimeout(() => {
        popupWindow.classList.add('hidden');
      }, 300);
    }
  }
</script>
