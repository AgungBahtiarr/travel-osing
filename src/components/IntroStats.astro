---
// IntroStats Component
// TripAdvisor-style clean editorial and statistics showcase.
import { ShieldCheck, Compass, Heart } from '@lucide/astro';
---

<section class="bg-bg-secondary py-20 border-b border-border-color relative">
  <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-[0.8fr_1.2fr] gap-12 lg:gap-16 items-center">
    
    <!-- Left text editorial -->
    <div class="text-center lg:text-left">
      <h3 class="font-sans text-3xl md:text-4xl text-text-main font-black tracking-tight mb-5">
        Perjalanan Aman,<br />Kenangan Berharga.
      </h3>
      <p class="text-text-muted text-base leading-relaxed font-medium">
        Kami berkomitmen menyajikan keindahan otentik Banyuwangi dengan standar kualitas premium. Bersama pemandu lokal berlisensi dari suku adat Osing asli, setiap langkah petualangan Anda terjamin aman dan menyenangkan.
      </p>
    </div>

    <!-- Right flat grids -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      
      <!-- Card 1 -->
      <div class="bg-white p-7.5 rounded-2xl border border-border-color text-center transition-all hover:shadow-md">
        <div class="w-12 h-12 rounded-full bg-primary-light flex items-center justify-center mx-auto mb-4 text-primary shrink-0">
          <ShieldCheck class="w-6 h-6" />
        </div>
        <span class="text-3xl font-black text-text-main mb-1.5 block tracking-tight">10+</span>
        <span class="text-xs font-extrabold text-text-main mb-1 block uppercase tracking-wider">Tahun Pengalaman</span>
        <span class="text-xs text-text-muted font-medium">Mengantarkan kebahagiaan petualang</span>
      </div>
      
      <!-- Card 2 -->
      <div class="bg-white p-7.5 rounded-2xl border border-border-color text-center transition-all hover:shadow-md">
        <div class="w-12 h-12 rounded-full bg-accent-light flex items-center justify-center mx-auto mb-4 text-accent shrink-0">
          <Compass class="w-6 h-6" />
        </div>
        <span class="text-3xl font-black text-accent mb-1.5 block tracking-tight">50+</span>
        <span class="text-xs font-extrabold text-text-main mb-1 block uppercase tracking-wider">Pemandu Lokal</span>
        <span class="text-xs text-text-muted font-medium">Asli suku Osing dan bersertifikat</span>
      </div>

      <!-- Card 3 -->
      <div class="bg-white p-7.5 rounded-2xl border border-border-color text-center transition-all hover:shadow-md">
        <div class="w-12 h-12 rounded-full bg-red-50 flex items-center justify-center mx-auto mb-4 text-red-500 shrink-0">
          <Heart class="w-6 h-6 fill-current" />
        </div>
        <span class="text-3xl font-black text-red-500 mb-1.5 block tracking-tight">15k+</span>
        <span class="text-xs font-extrabold text-text-main mb-1 block uppercase tracking-wider">Petualang Puas</span>
        <span class="text-xs text-text-muted font-medium">Dari nusantara hingga mancanegara</span>
      </div>
      
    </div>
  </div>
</section>
