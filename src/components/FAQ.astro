---
// FAQ Component
// Premium Accordion FAQ section for Travel Osing.
import { useTranslations } from '../utils/i18n';

const locale = Astro.currentLocale || 'id';
const t = useTranslations(locale);

const faqs = locale === 'en' ? [
  {
    q: "Is hiking Mount Ijen safe for beginners?",
    a: "Yes, it is very safe as long as you follow the guidance of our certified local guides. Although the trail is quite steep, it is wide and well-trodden. We recommend doing light leg exercises a few days beforehand and renting a gas mask to ensure safety around sulfur fumes."
  },
  {
    q: "When is the best time to visit Banyuwangi?",
    a: "The dry season, from July to September, is the perfect time. During these months, hiking trails are dry and less slippery, and the sky is clear, giving you the best chance to see the blue fire, Mount Ijen sunrise, and savanna wildlife in Baluran."
  },
  {
    q: "Are respirator gas masks included in the tour packages?",
    a: "Yes, all our Mount Ijen Midnight tour packages include certified gas respirator masks and safety headlamps. You do not need to buy or rent them separately."
  },
  {
    q: "How do I request a custom travel itinerary?",
    a: "You can easily design your custom trip using our interactive 'Trip Planner' section on this page, or click the WhatsApp floating button to consult directly with our travel representatives."
  }
] : [
  {
    q: "Apakah mendaki Kawah Ijen aman untuk pemula?",
    a: "Sangat aman selama Anda mengikuti arahan pemandu lokal berlisensi kami. Meskipun jalurnya cukup terjal, rutenya lebar dan terawat baik. Kami menyarankan untuk melakukan pemanasan kaki beberapa hari sebelum pendakian dan selalu menyewa masker respirator yang telah kami sediakan."
  },
  {
    q: "Kapan waktu terbaik berkunjung ke Banyuwangi?",
    a: "Waktu terbaik berkunjung adalah pada musim kemarau antara bulan Juli hingga September. Pada masa ini, rute pendakian kering dan tidak licin, langit sangat cerah, serta satwa liar di Sabana Baluran lebih mudah diamati berkumpul di dekat sumber air."
  },
  {
    q: "Apakah paket wisata sudah termasuk masker respirator?",
    a: "Ya, seluruh paket perjalanan Kawah Ijen dari Travel Osing sudah otomatis termasuk fasilitas peminjaman masker respirator standar keamanan tinggi dan senter kepala secara gratis. Anda tidak perlu menyewa lagi."
  },
  {
    q: "Bagaimana cara melakukan pemesanan kustom itinerary?",
    a: "Anda dapat merancang rencana liburan Anda secara mandiri di bagian 'Trip Planner' interaktif di halaman ini, atau menekan tombol obrolan WhatsApp untuk berdiskusi langsung dengan tim representative kami secara gratis."
  }
];
---

<section class="py-20 px-6 bg-bg-main border-b border-border-color" id="faq">
  <div class="max-w-4xl mx-auto px-6 relative">
    <div class="text-center max-w-[650px] mx-auto mb-15">
      <span class="inline-block text-[0.875rem] font-bold uppercase tracking-[0.15em] text-primary mb-3 bg-primary-light px-4 py-1.5 rounded-full">
        {t('faq.badge')}
      </span>
      <h2 class="font-sans text-3xl md:text-4xl text-text-main mb-4 leading-tight font-black tracking-tight">
        {t('faq.title')}
      </h2>
      <p class="text-text-muted text-base">
        {t('faq.subtitle')}
      </p>
    </div>

    <!-- FAQ Accordion List -->
    <div class="space-y-4" id="faq-accordion-group">
      {faqs.map((faq, index) => (
        <div class="faq-item bg-bg-secondary rounded-2xl border border-slate-100/80 overflow-hidden transition-all duration-300">
          <button 
            type="button" 
            class="faq-trigger w-full text-left px-6 py-5.5 md:px-8 md:py-6 flex items-center justify-between gap-4 font-bold text-text-main text-[1.05rem] transition-colors hover:text-primary focus:outline-none cursor-pointer"
            aria-expanded="false"
            aria-controls={`faq-answer-${index}`}
          >
            <span>{faq.q}</span>
            <svg class="faq-icon w-5 h-5 text-text-light shrink-0 transition-transform duration-300" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"></polyline></svg>
          </button>
          <div 
            id={`faq-answer-${index}`}
            class="faq-content max-h-0 overflow-hidden transition-all duration-300 ease-in-out bg-white/50"
            aria-hidden="true"
          >
            <p class="px-6 py-5 md:px-8 md:py-6 text-text-muted text-sm leading-relaxed font-medium">
              {faq.a}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  // Simple, high performance collapsible accordion logic
  document.addEventListener('DOMContentLoaded', () => {
    const faqTriggers = document.querySelectorAll('.faq-trigger');

    faqTriggers.forEach(trigger => {
      trigger.addEventListener('click', () => {
        const item = trigger.closest('.faq-item');
        const content = item?.querySelector('.faq-content') as HTMLElement;
        const icon = trigger.querySelector('.faq-icon');
        const isExpanded = trigger.getAttribute('aria-expanded') === 'true';

        // Close all other items for a clean TripAdvisor look
        document.querySelectorAll('.faq-item').forEach(otherItem => {
          if (otherItem !== item) {
            const otherTrigger = otherItem.querySelector('.faq-trigger');
            const otherContent = otherItem.querySelector('.faq-content') as HTMLElement;
            const otherIcon = otherItem.querySelector('.faq-icon');
            
            otherTrigger?.setAttribute('aria-expanded', 'false');
            otherContent?.setAttribute('aria-hidden', 'true');
            if (otherContent) otherContent.style.maxHeight = '0px';
            otherIcon?.classList.remove('rotate-180');
            otherItem.classList.remove('border-primary/30', 'shadow-sm');
          }
        });

        // Toggle current item
        if (isExpanded) {
          trigger.setAttribute('aria-expanded', 'false');
          content?.setAttribute('aria-hidden', 'true');
          if (content) content.style.maxHeight = '0px';
          icon?.classList.remove('rotate-180');
          item?.classList.remove('border-primary/30', 'shadow-sm');
        } else {
          trigger.setAttribute('aria-expanded', 'true');
          content?.setAttribute('aria-hidden', 'false');
          if (content) content.style.maxHeight = `${content.scrollHeight}px`;
          icon?.classList.add('rotate-180');
          item?.classList.add('border-primary/30', 'shadow-sm');
        }
      });
    });
  });
</script>
