---
// FAQ Component
// Premium Accordion FAQ section for Travel Osing.
---

<section class="py-20 px-6 bg-bg-main border-b border-border-color" id="faq">
  <div class="max-w-4xl mx-auto px-6 relative">
    <div class="text-center max-w-[650px] mx-auto mb-15">
      <span class="inline-block text-[0.875rem] font-bold uppercase tracking-[0.15em] text-primary mb-3 bg-primary-light px-4 py-1.5 rounded-full">
        Pertanyaan Umum
      </span>
      <h2 class="font-serif text-4xl md:text-[2.5rem] text-text-main mb-4 leading-tight font-extrabold">
        F.A.Q. Calon Wisatawan
      </h2>
      <p class="text-text-muted text-[1.125rem]">
        Temukan jawaban cepat atas pertanyaan yang sering diajukan mengenai petualangan premium Anda di Banyuwangi.
      </p>
    </div>

    <!-- FAQ Accordion List -->
    <div class="space-y-4" id="faq-accordion-group">
      
      <!-- FAQ 1 -->
      <div class="faq-item bg-bg-secondary rounded-2xl border border-slate-100/80 overflow-hidden transition-all duration-300">
        <button 
          type="button" 
          class="faq-trigger w-full text-left px-6 py-5.5 md:px-8 md:py-6 flex items-center justify-between gap-4 font-bold text-text-main text-[1.05rem] transition-colors hover:text-primary focus:outline-none cursor-pointer"
        >
          <span>Apakah mendaki Kawah Ijen aman untuk pemula?</span>
          <svg class="faq-icon w-5 h-5 text-text-light shrink-0 transition-transform duration-300" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"></polyline></svg>
        </button>
        <div class="faq-content max-h-0 overflow-hidden transition-all duration-300 ease-in-out">
          <div class="px-6 pb-6 pt-1 md:px-8 md:pb-7 text-[0.95rem] leading-relaxed text-text-muted">
            Sangat aman. Pemandu lokal berlisensi dari kami akan menemani setiap langkah pendakian Anda dengan kecepatan santai dan menyediakan alat pendukung lengkap seperti gas respirator berkualitas standar dan senter kepala secara gratis.
          </div>
        </div>
      </div>

      <!-- FAQ 2 -->
      <div class="faq-item bg-bg-secondary rounded-2xl border border-slate-100/80 overflow-hidden transition-all duration-300">
        <button 
          type="button" 
          class="faq-trigger w-full text-left px-6 py-5.5 md:px-8 md:py-6 flex items-center justify-between gap-4 font-bold text-text-main text-[1.05rem] transition-colors hover:text-primary focus:outline-none cursor-pointer"
        >
          <span>Kapan waktu terbaik untuk berkunjung ke Taman Nasional Baluran?</span>
          <svg class="faq-icon w-5 h-5 text-text-light shrink-0 transition-transform duration-300" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"></polyline></svg>
        </button>
        <div class="faq-content max-h-0 overflow-hidden transition-all duration-300 ease-in-out">
          <div class="px-6 pb-6 pt-1 md:px-8 md:pb-7 text-[0.95rem] leading-relaxed text-text-muted">
            Waktu terbaik adalah saat musim kemarau (Juli s.d. Oktober) di mana sabana rumput mengering sempurna menjadi warna keemasan eksotis mirip sabana liar di benua Afrika. Di musim ini, Anda juga lebih mudah melihat satwa liar berkumpul di kubangan air minum.
          </div>
        </div>
      </div>

      <!-- FAQ 3 -->
      <div class="faq-item bg-bg-secondary rounded-2xl border border-slate-100/80 overflow-hidden transition-all duration-300">
        <button 
          type="button" 
          class="faq-trigger w-full text-left px-6 py-5.5 md:px-8 md:py-6 flex items-center justify-between gap-4 font-bold text-text-main text-[1.05rem] transition-colors hover:text-primary focus:outline-none cursor-pointer"
        >
          <span>Apa keunikan Paket Budaya Adat Kemiren dibanding tour biasa?</span>
          <svg class="faq-icon w-5 h-5 text-text-light shrink-0 transition-transform duration-300" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"></polyline></svg>
        </button>
        <div class="faq-content max-h-0 overflow-hidden transition-all duration-300 ease-in-out">
          <div class="px-6 pb-6 pt-1 md:px-8 md:pb-7 text-[0.95rem] leading-relaxed text-text-muted">
            Pada Paket Budaya kami, Anda tidak hanya berkunjung sebagai penonton biasa, melainkan melebur dalam keseharian suku Osing. Mulai dari menumbuk padi tradisional di lumpang besar, mencicipi kuliner khas Pecel Pitik langsung di rumah adat, hingga ikut menumbuk dan menyeduh "Kopai Osing" yang melegenda.
          </div>
        </div>
      </div>

      <!-- FAQ 4 -->
      <div class="faq-item bg-bg-secondary rounded-2xl border border-slate-100/80 overflow-hidden transition-all duration-300">
        <button 
          type="button" 
          class="faq-trigger w-full text-left px-6 py-5.5 md:px-8 md:py-6 flex items-center justify-between gap-4 font-bold text-text-main text-[1.05rem] transition-colors hover:text-primary focus:outline-none cursor-pointer"
        >
          <span>Bagaimana dengan sistem penjemputan peserta tour dari luar kota?</span>
          <svg class="faq-icon w-5 h-5 text-text-light shrink-0 transition-transform duration-300" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"></polyline></svg>
        </button>
        <div class="faq-content max-h-0 overflow-hidden transition-all duration-300 ease-in-out">
          <div class="px-6 pb-6 pt-1 md:px-8 md:pb-7 text-[0.95rem] leading-relaxed text-text-muted">
            Kami melayani penjemputan gratis dan fleksibel dari stasiun kereta api Banyuwangi, bandara Blimbingsari, pelabuhan Ketapang, atau hotel manapun di sekitar area pusat kota Banyuwangi. Jadwal penjemputan akan disesuaikan dengan tiket kedatangan perjalanan Anda.
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- Accordion Toggle JavaScript -->
<script>
  const faqTriggers = document.querySelectorAll('.faq-trigger');

  faqTriggers.forEach(trigger => {
    trigger.addEventListener('click', (e) => {
      const currentButton = e.currentTarget as HTMLButtonElement;
      const currentItem = currentButton.closest('.faq-item') as HTMLElement;
      const currentContent = currentItem.querySelector('.faq-content') as HTMLElement;
      const currentIcon = currentItem.querySelector('.faq-icon') as HTMLElement;

      const isOpen = currentContent.style.maxHeight && currentContent.style.maxHeight !== '0px';

      // Close all other items
      document.querySelectorAll('.faq-item').forEach(item => {
        const itemContent = item.querySelector('.faq-content') as HTMLElement;
        const itemIcon = item.querySelector('.faq-icon') as HTMLElement;
        if (itemContent && itemIcon) {
          itemContent.style.maxHeight = '0px';
          itemIcon.style.transform = 'rotate(0deg)';
          item.classList.remove('border-primary/20', 'bg-primary-light/30', 'shadow-[0_4px_20px_rgba(54,167,226,0.03)]');
        }
      });

      if (!isOpen) {
        // Expand the clicked item
        currentContent.style.maxHeight = `${currentContent.scrollHeight}px`;
        if (currentIcon) currentIcon.style.transform = 'rotate(180deg)';
        currentItem.classList.add('border-primary/20', 'bg-primary-light/30', 'shadow-[0_4px_20px_rgba(54,167,226,0.03)]');
      }
    });
  });
</script>
