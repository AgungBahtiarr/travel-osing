---
import { getCollection, render } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar.astro';
import Footer from '../../../components/Footer.astro';
import WhatsAppWidget from '../../../components/WhatsAppWidget.astro';
import { 
  ChevronLeft, 
  MapPin, 
  Star, 
  CheckCircle2, 
  Info, 
  ShieldCheck, 
  ArrowRight, 
  Briefcase, 
  Share2, 
  MessageCircle,
  Clock,
  Compass
} from '@lucide/astro';
import { Image } from 'astro:assets';
import { useTranslations } from '../../../utils/i18n';

// 1. Generate paths for English destinations
export async function getStaticPaths() {
  const destinations = await getCollection('destinations');
  const enDestinations = destinations.filter(d => d.id.startsWith('en/'));
  return enDestinations.map(dest => ({
    params: { id: dest.id.replace(/^en\//, '') },
    props: { dest },
  }));
}

const { dest } = Astro.props;
const { Content } = await render(dest);
const locale = 'en';
const t = useTranslations(locale);

// Curated premium structured data for Banyuwangi destinations (English Version)
const destinationDetails: Record<string, { highlights: string[], itinerary: { time: string, activity: string }[], tips: string[] }> = {
  'kawah-ijen': {
    highlights: [
      "Witness the electric blue fire phenomenon, a rare wonder of the world.",
      "Marvel at the world's largest acidic crater lake with stunning turquoise water.",
      "Enjoy the magical sunrise views from the peak of Mount Ijen.",
      "See up close the remarkable struggle of the traditional sulfur miners."
    ],
    itinerary: [
      { time: "23:30 - 00:30", activity: "Hotel/station pickup in Banyuwangi and journey to Pos Paltuding." },
      { time: "00:30 - 02:00", activity: "Arrival at Paltuding, safety briefing, gas mask & headlamp distribution." },
      { time: "02:00 - 03:30", activity: "Hike to the rim of Ijen Crater (3 km) guided by our certified local guide." },
      { time: "03:30 - 05:00", activity: "Descent into the crater to witness the Blue Fire & traditional sulfur mining." },
      { time: "05:00 - 06:30", activity: "Return to the rim to enjoy the sunrise and the majestic turquoise acidic lake view." },
      { time: "06:30 - 08:00", activity: "Hike back down to Pos Paltuding." },
      { time: "08:00 - 09:00", activity: "Drive back to Banyuwangi and drop-off at your hotel." }
    ],
    tips: [
      "Wear a warm jacket, gloves, and a beanie as temperatures can drop to 5-10°C at the peak.",
      "Use hiking boots or running shoes with good anti-slip rubber outsoles.",
      "Bring sufficient drinking water and high-energy snacks (chocolate/biscuits).",
      "Asthma patients or those with severe respiratory issues are strictly advised not to descend into the crater."
    ]
  },
  'de-djawatan': {
    highlights: [
      "Take photos amidst giant mossy Trembesi trees resembling the fantasy Lord of the Rings forest.",
      "Breathe natural, pollution-free clean air beneath a massive green tree canopy.",
      "Explore the aesthetic wooden bridges and iconic treehouse photo spots.",
      "Try optional activities like horseback riding or riding a traditional carriage."
    ],
    itinerary: [
      { time: "08:30 - 09:30", activity: "Pickup at your hotel in Banyuwangi and travel to Benculuk." },
      { time: "09:30 - 10:00", activity: "Arrival at De Djawatan, premium ticket registration, and camera preparation." },
      { time: "10:00 - 12:00", activity: "Walk along the ancient trembesi forest paths accompanied by our local guide." },
      { time: "12:00 - 13:00", activity: "Enjoy a lunch of legendary local culinary specialties (Sego Tempong)." },
      { time: "13:00 - 14:00", activity: "Relaxed journey back to your pickup hotel." }
    ],
    tips: [
      "The best light for photos is 09:00-11:00 or 15:30-16:30 to catch dramatic sunbeams (ray of light).",
      "Wear contrasting colors (like white or yellow) to stand out against the deep green forest backdrop.",
      "Apply mosquito repellent as the forest humidity can be relatively high.",
      "Avoid climbing or damaging the ancient tree branches to preserve this nature reserve."
    ]
  },
  'pulau-merah': {
    highlights: [
      "Witness one of the most beautiful sunsets in Java against the iconic red island silhouette.",
      "Swim or learn to surf at the beach with tourist-friendly waves and soft pinkish sand.",
      "Walk across the beach sandbar to the Red Island hill when the tide is low.",
      "Relax under iconic red beach umbrellas while enjoying fresh coconut water."
    ],
    itinerary: [
      { time: "13:00 - 14:30", activity: "Pickup at your Banyuwangi hotel and overland trip to Pesanggaran." },
      { time: "14:30 - 15:00", activity: "Arrival at Red Island Beach, settling into your relaxing beach umbrella spot." },
      { time: "15:00 - 17:00", activity: "Free activities: safe swimming, capturing aesthetic photos, or a beginner surf lesson." },
      { time: "17:00 - 18:00", activity: "Watch and capture the magical golden sunset behind the iconic red island hill." },
      { time: "18:00 - 19:30", activity: "Relaxed return drive to your hotel in Banyuwangi." }
    ],
    tips: [
      "Bring a spare set of dry clothes, towels, and waterproof bags for gadgets.",
      "Use high-SPF sunscreen and wear polarized sunglasses for beach protection.",
      "Rent certified surfboards through our guide's recommendation for safety.",
      "Always check the red flag zone markers placed by lifeguards on the shoreline."
    ]
  },
  'taman-baluran': {
    highlights: [
      "Explore Bekol Savanna, the largest natural savanna in Java, nicknamed 'Africa van Java'.",
      "Spot wild deer, green peacocks, grey macaques, and the endangered Javan banteng in their wild habitat.",
      "Visit tranquil Bama Beach, surrounded by pristine ancient mangrove conservation forests.",
      "Capture exotic photos at the dry tree gateway, iconic to dry seasonal weather."
    ],
    itinerary: [
      { time: "07:30 - 08:30", activity: "Pickup from your hotel and drive to Wongsorejo on the northern border." },
      { time: "08:30 - 09:30", activity: "Enter Baluran main gates, driving through the lush shade of the Evergreen Forest." },
      { time: "09:30 - 11:30", activity: "Explore Bekol Savanna, climb the watchtower, and capture stunning landscape photos." },
      { time: "11:30 - 13:30", activity: "Visit Bama Beach, enjoy lunch, and walk along the pristine mangrove forest trail." },
      { time: "13:30 - 15:00", activity: "Relaxed drive back to your hotel in Banyuwangi city." }
    ],
    tips: [
      "Wear light, breathable cotton clothing as the savanna climate can be quite hot.",
      "Bring binoculars or a camera with a long telephoto lens to photograph wildlife from a safe distance.",
      "Do not carry red or bright plastic bags, as grey macaques at Bama Beach are very aggressive for food.",
      "Always follow your guide's instructions and avoid loud noises in the wildlife sanctuary."
    ]
  }
};

const currentSlug = dest.id.replace(/^en\//, '');
const details = destinationDetails[currentSlug] || {
  highlights: [
    "Explore the authentic natural beauty of Banyuwangi.",
    "Accompanied by professional local guides licensed by travel authorities.",
    "Premium air-conditioned transport that is clean and comfortable.",
    "Flexible custom itineraries designed around your interests."
  ],
  itinerary: [
    { time: "08:00 - 09:00", activity: "Pickup from hotel/station in Banyuwangi." },
    { time: "09:00 - 12:00", activity: "Destination exploration and guided activities." },
    { time: "12:00 - 13:00", activity: "Local culinary lunch experience." },
    { time: "13:00 - 15:00", activity: "Further sightseeing at selected highlight spots." },
    { time: "15:00 - 16:00", activity: "Return drive to your accommodation." }
  ],
  tips: [
    "Wear comfortable clothing suitable for your travel destination.",
    "Keep your camera ready to capture beautiful adventure memories.",
    "Always follow safety instructions provided by our local guide."
  ]
};

// 3. Fetch other English destinations
const allDestinations = await getCollection('destinations');
const otherDestinations = allDestinations
  .filter(d => d.id.startsWith('en/') && d.id !== dest.id)
  .slice(0, 3);

// WhatsApp Direct Booking Text Formatter (English)
const waText = encodeURIComponent(
  `Hello Travel Osing!\nI am interested in booking a premium tour package to:\n` +
  `📍 Destination: ${dest.data.title}\n` +
  `💰 Rate: Rp ${dest.data.price.toLocaleString('id-ID')} / ${dest.data.priceUnit === 'pax' ? t('dest.price.unit') : dest.data.priceUnit}\n\n` +
  `Please let me know the availability of local guides for our trip. Thank you!`
);
---

<Layout 
  title={`${dest.data.title} - Explore Banyuwangi | Travel Osing`} 
  description={dest.data.description}
  image={dest.data.image}
>
  <!-- Navigation Header -->
  <Navbar />

  <main class="bg-bg-main min-h-screen pb-24">
    <article>
      <!-- TripAdvisor Premium Hero Header -->
      <header class="py-12 md:py-16 bg-bg-secondary border-b border-border-color">
        <div class="max-w-7xl mx-auto px-6">
          
          <!-- Back button -->
          <a 
            href="/en/#destinasi" 
            class="inline-flex items-center gap-1.5 text-xs font-extrabold uppercase tracking-wider text-text-light hover:text-primary transition-all mb-8 group"
          >
            <ChevronLeft class="w-4 h-4 group-hover:-translate-x-0.5 transition-transform" />
            Back to Home
          </a>

          <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6">
            <div class="text-left max-w-3xl">
              <!-- Category badge -->
              <span class="inline-block bg-primary-light text-primary font-extrabold text-[0.65rem] px-3 py-1 rounded-full uppercase tracking-wider mb-4 border border-primary/10 select-none">
                {dest.data.category}
              </span>
              
              <!-- Title -->
              <h1 class="font-sans text-3xl md:text-4xl lg:text-5xl font-black text-text-main tracking-tight leading-tight mb-4">
                {dest.data.title}
              </h1>

              <!-- TripAdvisor Bubble Rating & Reviews -->
              <div class="flex items-center gap-3">
                <div class="flex gap-0.5" aria-label={`Rating ${dest.data.rating} out of 5`}>
                  {Array.from({ length: 5 }).map((_, i) => (
                    <span class={`w-3.5 h-3.5 rounded-full inline-block ${i < Math.round(dest.data.rating) ? 'bg-[#00aa6c]' : 'bg-[#00aa6c]/20 border border-[#00aa6c]/10'}`}></span>
                  ))}
                </div>
                <span class="text-sm font-bold text-text-main">{dest.data.rating}</span>
                <span class="text-text-light text-sm font-medium">({dest.data.reviewsCount} Traveler Reviews)</span>
              </div>
            </div>

            <!-- Header Price block for mobile responsiveness -->
            <div class="lg:text-right shrink-0 border-t lg:border-t-0 border-border-color pt-6 lg:pt-0">
              <span class="text-xs text-text-light font-bold uppercase tracking-wider block mb-1">{t('dest.price.from')}</span>
              <p class="text-2xl md:text-3xl font-black text-text-main tracking-tight">
                Rp {dest.data.price.toLocaleString('id-ID')} <span class="text-sm text-text-light font-medium">/{dest.data.priceUnit === 'pax' ? t('dest.price.unit') : dest.data.priceUnit}</span>
              </p>
            </div>
          </div>

        </div>
      </header>

      <!-- Main Glorious Image with Explicit Sizing -->
      <div class="max-w-7xl mx-auto px-6 -mt-8 md:-mt-12 relative z-10">
        <div class="aspect-[16/9] md:aspect-[21/9] w-full rounded-2xl overflow-hidden border border-border-color shadow-lg bg-slate-100">
          <Image 
            src={dest.data.image} 
            alt={dest.data.title}
            width={1280}
            height={640}
            class="w-full h-full object-cover object-center animate-image-load"
          />
        </div>
      </div>

      <!-- Content Layout Columns -->
      <div class="max-w-7xl mx-auto px-6 mt-12 md:mt-16">
        <div class="grid grid-cols-1 lg:grid-cols-[1.4fr_0.8fr] gap-10 items-start relative">
          
          <!-- Left Main Column (Detailed info) -->
          <div class="space-y-12">
            
            <!-- Description Card -->
            <section class="bg-white p-8 rounded-2xl border border-border-color shadow-sm text-left">
              <h2 class="font-sans text-xl md:text-2xl font-black text-text-main mb-5 flex items-center gap-2.5 pb-4 border-b border-border-color">
                <Compass class="w-5.5 h-5.5 text-primary" />
                About This Destination
              </h2>
              <div class="prose-custom">
                <p class="font-medium text-text-muted leading-relaxed text-base mb-6">
                  {dest.data.description}
                </p>
                <Content />
              </div>
            </section>

            <!-- Highlights Section -->
            <section class="bg-white p-8 rounded-2xl border border-border-color shadow-sm text-left">
              <h2 class="font-sans text-xl md:text-2xl font-black text-text-main mb-5 flex items-center gap-2.5 pb-4 border-b border-border-color">
                <Star class="w-5.5 h-5.5 text-accent" />
                Premium Experience Highlights
              </h2>
              <ul class="space-y-4">
                {details.highlights.map((highlight) => (
                  <li class="flex items-start gap-3">
                    <CheckCircle2 class="w-5 h-5 text-accent shrink-0 mt-0.5" />
                    <span class="text-sm font-semibold text-text-muted leading-relaxed">{highlight}</span>
                  </li>
                ))}
              </ul>
            </section>

            <!-- Curated Brief Itinerary -->
            <section class="bg-white p-8 rounded-2xl border border-border-color shadow-sm text-left">
              <h2 class="font-sans text-xl md:text-2xl font-black text-text-main mb-6 flex items-center gap-2.5 pb-4 border-b border-border-color">
                <Clock class="w-5.5 h-5.5 text-primary" />
                Standard Travel Itinerary
              </h2>
              <div class="relative border-l border-slate-200 ml-3 pl-6 space-y-8 py-2">
                {details.itinerary.map((item) => (
                  <div class="relative">
                    <!-- Dot marker -->
                    <div class="absolute -left-[31px] top-1.5 w-3 h-3 rounded-full bg-primary border-2 border-white ring-4 ring-primary-light"></div>
                    <div class="flex flex-col sm:flex-row sm:items-start gap-1 sm:gap-6">
                      <span class="text-xs font-black text-primary uppercase tracking-wider shrink-0 bg-primary-light px-2.5 py-1 rounded-md border border-primary/5">{item.time}</span>
                      <p class="text-sm font-bold text-text-muted leading-relaxed">{item.activity}</p>
                    </div>
                  </div>
                ))}
              </div>
            </section>

            <!-- Smart Traveler Tips -->
            <section class="bg-white p-8 rounded-2xl border border-border-color shadow-sm text-left">
              <h2 class="font-sans text-xl md:text-2xl font-black text-text-main mb-5 flex items-center gap-2.5 pb-4 border-b border-border-color">
                <Info class="w-5.5 h-5.5 text-amber-500" />
                Essential Preparation Tips
              </h2>
              <ul class="space-y-4">
                {details.tips.map((tip) => (
                  <li class="flex items-start gap-3.5">
                    <div class="w-5 h-5 rounded-full bg-amber-50 border border-amber-200 flex items-center justify-center text-amber-600 shrink-0 text-xs font-bold mt-0.5">!</div>
                    <span class="text-sm font-semibold text-text-muted leading-relaxed">{tip}</span>
                  </li>
                ))}
              </ul>
            </section>

          </div>

          <!-- Right Sidebar Column (Sticky Booking Spec Card) -->
          <div class="space-y-6 lg:sticky lg:top-28">
            <div class="bg-white p-8 rounded-2xl border border-border-color shadow-md flex flex-col">
              <!-- Card Header title -->
              <div class="border-b border-border-color pb-5 mb-5 select-none text-left">
                <span class="text-[0.65rem] text-primary font-black uppercase tracking-wider block mb-1">Exclusive Reservation</span>
                <h3 class="text-lg font-black text-text-main">Booking Sheet</h3>
              </div>

              <!-- Price highlights inside card -->
              <div class="flex justify-between items-end mb-6 text-left">
                <div>
                  <span class="text-[0.65rem] text-text-light font-bold uppercase tracking-wider block mb-0.5 select-none">{t('dest.price.from')}</span>
                  <span class="text-2xl font-black text-text-main tracking-tight">Rp {dest.data.price.toLocaleString('id-ID')}</span>
                </div>
                <div class="text-right">
                  <span class="text-xs text-text-light font-bold uppercase tracking-wider block mb-0.5 select-none">Per Person</span>
                  <span class="text-sm font-extrabold text-accent bg-accent-light px-2.5 py-1 rounded-md">100% {dest.data.priceUnit === 'pax' ? t('dest.price.unit') : dest.data.priceUnit}</span>
                </div>
              </div>

              <!-- Trust bulletpoints list -->
              <div class="border-t border-b border-dashed border-border-color py-5 my-5 space-y-3.5 text-left">
                <div class="flex items-center gap-3 text-xs font-bold text-text-muted">
                  <ShieldCheck class="w-4.5 h-4.5 text-accent shrink-0" />
                  <span>Best Price Guarantee With Zero Hidden Fees</span>
                </div>
                <div class="flex items-center gap-3 text-xs font-bold text-text-muted">
                  <CheckCircle2 class="w-4.5 h-4.5 text-accent shrink-0" />
                  <span>Officially Licensed Native Osing Local Guides</span>
                </div>
                <div class="flex items-center gap-3 text-xs font-bold text-text-muted">
                  <Briefcase class="w-4.5 h-4.5 text-accent shrink-0" />
                  <span>Includes Travel Insurance & Premium AC Transport</span>
                </div>
              </div>

              <!-- Booking Direct CTA -->
              <a 
                href={`https://wa.me/6281234567890?text=${waText}`} 
                target="_blank"
                class="w-full bg-accent hover:bg-accent-hover text-white font-extrabold text-center py-4 px-6 rounded-full block shadow-sm text-sm tracking-wide transition-all hover:-translate-y-0.5"
              >
                Book This Trip Package Now
              </a>

              <!-- Bottom alternative link -->
              <a 
                href="/en/#rencana" 
                class="text-xs text-primary hover:underline font-extrabold text-center mt-5 uppercase tracking-wider flex items-center justify-center gap-1"
              >
                Customize Itinerary <ArrowRight class="w-3.5 h-3.5" />
              </a>
            </div>

            <!-- Share & Contact mini card -->
            <div class="bg-bg-secondary p-5 rounded-2xl border border-border-color shadow-sm flex items-center justify-between">
              <span class="text-xs font-bold text-text-muted">Share Destination:</span>
              <div class="flex items-center gap-2">
                <button 
                  type="button" 
                  onclick="navigator.clipboard.writeText(window.location.href); alert('Destination link copied to clipboard!');"
                  class="w-9 h-9 rounded-full border border-border-color hover:bg-white bg-slate-50 flex items-center justify-center text-text-muted hover:text-primary transition-all cursor-pointer shadow-subtle active:scale-95"
                  title="Copy Link"
                >
                  <Share2 class="w-3.5 h-3.5" />
                </button>
                <a 
                  href="#"
                  id="whatsapp-dest-share"
                  target="_blank"
                  class="w-9 h-9 rounded-full border border-border-color hover:bg-white bg-slate-50 flex items-center justify-center text-text-muted hover:text-accent transition-all cursor-pointer shadow-subtle active:scale-95"
                  title="Share to WhatsApp"
                >
                  <MessageCircle class="w-3.5 h-3.5" />
                </a>
              </div>
            </div>
          </div>

        </div>
      </div>
    </article>

    <!-- Bottom Related / More Destinations Section -->
    {otherDestinations.length > 0 && (
      <section class="mt-24 py-16 bg-bg-secondary border-t border-b border-border-color px-6">
        <div class="max-w-7xl mx-auto">
          <div class="flex items-center justify-between mb-10 px-6">
            <h3 class="font-sans text-xl md:text-2xl font-black text-text-main tracking-tight">More Banyuwangi Destinations</h3>
            <a href="/en/#destinasi" class="text-xs font-bold text-primary hover:underline flex items-center gap-1 uppercase tracking-wider">
              View all destinations <ArrowRight class="w-3.5 h-3.5" />
            </a>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {otherDestinations.map((od) => (
              <a 
                href={`/en/destinations/${od.id.replace(/^en\//, '')}`}
                class="group bg-white rounded-2xl overflow-hidden border border-border-color hover:border-slate-300 hover:shadow-md transition-all duration-300 flex flex-col text-left shadow-sm"
              >
                <div class="aspect-[4/3] w-full overflow-hidden bg-slate-100 border-b border-border-color">
                  <Image 
                    src={od.data.image} 
                    alt={od.data.title}
                    width={400}
                    height={300}
                    class="w-full h-full object-cover object-center group-hover:scale-103 transition-transform duration-300"
                  />
                </div>
                <div class="p-6 flex flex-col flex-grow">
                  <span class="text-[0.65rem] font-bold text-primary uppercase tracking-wider mb-2">
                    {od.data.category}
                  </span>
                  <h4 class="font-sans font-black text-text-main leading-snug group-hover:text-primary transition-colors text-lg mb-2">
                    {od.data.title}
                  </h4>
                  <p class="text-text-muted text-xs leading-relaxed line-clamp-2 flex-grow">
                    {od.data.description}
                  </p>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}
  </main>

  <!-- Footer Section -->
  <Footer />

  <!-- Floating WhatsApp Widget -->
  <WhatsAppWidget />
</Layout>

<script define:vars={{ title: dest.data.title }}>
  document.addEventListener('DOMContentLoaded', () => {
    const waShare = document.getElementById('whatsapp-dest-share');
    if (waShare) {
      waShare.href = `https://api.whatsapp.com/send?text=${encodeURIComponent('Explore the gorgeous ' + title + ' in Banyuwangi with Travel Osing: ' + window.location.href)}`;
    }
  });
</script>

<style is:global>
  /* Premium Custom Typography variables styling for Markdown rendered articles */
  .prose-custom h2 {
    font-family: "Plus Jakarta Sans", system-ui, -apple-system, sans-serif;
    font-size: 1.625rem;
    font-weight: 800;
    color: var(--color-text-main);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    line-height: 1.3;
    letter-spacing: -0.02em;
  }
  
  .prose-custom h3 {
    font-family: "Plus Jakarta Sans", system-ui, -apple-system, sans-serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text-main);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }

  .prose-custom p {
    font-size: 1.05rem;
    color: var(--color-text-muted);
    line-height: 1.75;
    margin-bottom: 1.5rem;
  }

  .prose-custom strong {
    color: var(--color-text-main);
    font-weight: 700;
  }

  .prose-custom ul {
    list-style-type: disc;
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
    margin-top: -0.5rem;
  }

  .prose-custom li {
    font-size: 1.05rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: 0.5rem;
  }

  .prose-custom blockquote {
    border-left: 4px solid var(--color-primary);
    background-color: var(--color-bg-secondary);
    padding: 1.25rem 1.75rem;
    border-radius: 0 0.75rem 0.75rem 0;
    font-style: italic;
    color: var(--color-text-muted);
    margin: 2rem 0;
  }
  
  .prose-custom em {
    font-style: italic;
  }
</style>
