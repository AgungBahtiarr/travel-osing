---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import WhatsAppWidget from '../../components/WhatsAppWidget.astro';
import { Calendar, User, Clock, ChevronLeft, ArrowRight, Share2, MessageCircle } from '@lucide/astro';

// 1. Generate paths for each blog entry
export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { id: post.id },
    props: { post },
  }));
}

// 2. Fetch data from props and render markdown content
const { post } = Astro.props;
const { Content } = await render(post);

// 3. Get related articles (exclude current, find common tags, or get latest)
const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter(p => p.id !== post.id)
  .map(p => {
    // Count common tags for sorting relevancy
    const commonTags = p.data.tags.filter(t => post.data.tags.includes(t)).length;
    return { post: p, commonTags };
  })
  .sort((a, b) => b.commonTags - a.commonTags || b.post.data.pubDate.getTime() - a.post.data.pubDate.getTime())
  .slice(0, 2)
  .map(item => item.post);

// Format date helper
const formatDate = (date: Date) => {
  return new Intl.DateTimeFormat('id-ID', {
    day: 'numeric',
    month: 'long',
    year: 'numeric'
  }).format(date);
};
---

<Layout 
  title={`${post.data.title} - Blog Travel Osing`} 
  description={post.data.excerpt}
  image={post.data.image}
>
  <!-- Navigation Header -->
  <Navbar />

  <main class="bg-bg-main min-h-screen pb-24">
    
    <!-- Floating Article Progress Bar or Top Nav -->
    <article class="relative">
      
      <!-- Premium Hero Header -->
      <header class="py-12 md:py-16 bg-bg-secondary border-b border-border-color">
        <div class="max-w-4xl mx-auto px-6">
          
          <!-- Back button -->
          <a 
            href="/blog" 
            class="inline-flex items-center gap-1.5 text-xs font-extrabold uppercase tracking-wider text-text-light hover:text-primary transition-all mb-8 group"
          >
            <ChevronLeft class="w-4 h-4 group-hover:-translate-x-0.5 transition-transform" />
            Kembali ke Blog
          </a>

          <!-- Category Tags -->
          <div class="flex flex-wrap gap-2 mb-4">
            {post.data.tags.map((tag) => (
              <span class="inline-block bg-white text-text-muted font-bold text-[0.7rem] px-3 py-1.5 rounded-full border border-border-color/80 uppercase tracking-wider">
                {tag}
              </span>
            ))}
          </div>

          <!-- Article Title -->
          <h1 class="font-sans text-3xl md:text-4xl lg:text-5xl font-black text-text-main tracking-tight leading-tight mb-6">
            {post.data.title}
          </h1>

          <!-- Meta Author/Date/Read Row -->
          <div class="flex flex-wrap items-center gap-6 text-sm text-text-light border-t border-border-color/60 pt-6">
            <!-- Author -->
            <div class="flex items-center gap-2">
              <div class="w-7 h-7 rounded-full bg-white flex items-center justify-center border border-border-color shrink-0">
                <User class="w-3.5 h-3.5 text-text-muted" />
              </div>
              <div>
                <span class="text-text-muted font-bold text-xs">Penulis</span>
                <p class="font-semibold text-text-main text-xs">{post.data.author}</p>
              </div>
            </div>

            <!-- Date -->
            <div class="flex items-center gap-2">
              <div class="w-7 h-7 rounded-full bg-white flex items-center justify-center border border-border-color shrink-0">
                <Calendar class="w-3.5 h-3.5 text-text-muted" />
              </div>
              <div>
                <span class="text-text-muted font-bold text-xs">Tanggal Rilis</span>
                <p class="font-semibold text-text-main text-xs">{formatDate(post.data.pubDate)}</p>
              </div>
            </div>

            <!-- Read Time -->
            <div class="flex items-center gap-2">
              <div class="w-7 h-7 rounded-full bg-white flex items-center justify-center border border-border-color shrink-0">
                <Clock class="w-3.5 h-3.5 text-text-muted" />
              </div>
              <div>
                <span class="text-text-muted font-bold text-xs">Durasi Baca</span>
                <p class="font-semibold text-text-main text-xs">{post.data.readTime} Baca</p>
              </div>
            </div>
          </div>

        </div>
      </header>

      <!-- Featured Image -->
      <div class="max-w-4xl mx-auto px-6 -mt-8 md:-mt-12 relative z-10">
        <div class="aspect-[16/9] md:aspect-[21/9] w-full rounded-2xl overflow-hidden border border-border-color shadow-lg bg-slate-100">
          <img 
            src={post.data.image} 
            alt={post.data.title}
            class="w-full h-full object-cover object-center"
          />
        </div>
      </div>

      <!-- Main Article Body -->
      <div class="max-w-4xl mx-auto px-6 mt-12 flex flex-col lg:flex-row gap-12 relative">
        
        <!-- Social Share Sidebar (sticky desktop) -->
        <aside class="lg:w-16 shrink-0 flex lg:flex-col items-center justify-start gap-3 py-2 border-b lg:border-b-0 lg:border-r border-border-color lg:pr-6 self-start lg:sticky lg:top-28">
          <span class="text-[0.65rem] font-bold uppercase tracking-wider text-text-light lg:mb-2 whitespace-nowrap">Bagikan</span>
          <button 
            type="button" 
            onclick="navigator.clipboard.writeText(window.location.href); alert('Tautan artikel berhasil disalin!');"
            class="w-10 h-10 rounded-full border border-border-color hover:bg-slate-50 flex items-center justify-center text-text-muted hover:text-primary transition-all cursor-pointer shadow-subtle active:scale-95"
            title="Salin Tautan"
          >
            <Share2 class="w-4 h-4" />
          </button>
          <a 
            href="#"
            id="whatsapp-share-btn"
            target="_blank"
            class="w-10 h-10 rounded-full border border-border-color hover:bg-slate-50 flex items-center justify-center text-text-muted hover:text-accent transition-all cursor-pointer shadow-subtle active:scale-95"
            title="Bagikan ke WhatsApp"
          >
            <MessageCircle class="w-4 h-4" />
          </a>
        </aside>

        <!-- Markdown Rendered Content -->
        <div class="flex-grow max-w-3xl prose-custom">
          <Content />
          
          <!-- Conversion Banner Box -->
          <div class="mt-16 p-8 rounded-2xl border border-border-color bg-bg-secondary flex flex-col sm:flex-row items-center gap-6 shadow-subtle">
            <div class="text-left flex-grow">
              <span class="inline-block text-[0.65rem] font-extrabold text-primary uppercase tracking-[0.2em] mb-1">Eksplorasi Bersama Kami</span>
              <h4 class="font-sans text-lg font-black text-text-main mb-2">Ingin merencanakan liburan ke Banyuwangi?</h4>
              <p class="text-text-muted text-xs leading-relaxed max-w-md">
                Hubungi kami sekarang untuk berkonsultasi gratis dan dapatkan penawaran itinerary premium khusus untuk Anda dan keluarga.
              </p>
            </div>
            <a 
              href="https://wa.me/628123456789?text=Halo%20Travel%20Osing,%20saya%20tertarik%20dengan%20info%20dari%20artikel%20blog%20Anda."
              target="_blank"
              class="inline-flex items-center gap-2 px-6 py-3.5 rounded-full bg-accent hover:bg-accent-hover text-white font-bold text-xs uppercase tracking-wider transition-all shadow-sm shrink-0 whitespace-nowrap active:scale-95 cursor-pointer"
            >
              Hubungi WhatsApp
              <ArrowRight class="w-4 h-4" />
            </a>
          </div>
        </div>

      </div>
    </article>

    <!-- Bottom Related Articles Section -->
    {relatedPosts.length > 0 && (
      <section class="mt-24 py-16 bg-bg-secondary border-t border-b border-border-color px-6">
        <div class="max-w-4xl mx-auto">
          <div class="flex items-center justify-between mb-8">
            <h3 class="font-sans text-xl md:text-2xl font-black text-text-main tracking-tight">Artikel Terkait</h3>
            <a href="/blog" class="text-xs font-bold text-primary hover:underline flex items-center gap-1">
              Lihat semua <ArrowRight class="w-3.5 h-3.5" />
            </a>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            {relatedPosts.map((rPost) => (
              <a 
                href={`/blog/${rPost.id}`}
                class="group bg-white rounded-xl overflow-hidden border border-border-color hover:border-slate-300 hover:shadow-md transition-all duration-300 flex flex-col"
              >
                <div class="aspect-[16/9] w-full overflow-hidden bg-slate-100 border-b border-border-color">
                  <img 
                    src={rPost.data.image} 
                    alt={rPost.data.title}
                    class="w-full h-full object-cover object-center group-hover:scale-103 transition-transform duration-300"
                  />
                </div>
                <div class="p-5 flex flex-col flex-grow">
                  <div class="flex items-center gap-1 text-[0.7rem] font-bold text-primary uppercase tracking-wide mb-1.5">
                    <Clock class="w-3 h-3" />
                    {rPost.data.readTime}
                  </div>
                  <h4 class="font-sans font-bold text-text-main leading-snug group-hover:text-primary transition-colors text-base line-clamp-2 mb-2">
                    {rPost.data.title}
                  </h4>
                  <p class="text-text-muted text-xs leading-relaxed line-clamp-2 flex-grow">
                    {rPost.data.excerpt}
                  </p>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

  </main>

  <!-- Footer Section -->
  <Footer />

  <!-- Floating WhatsApp Widget -->
  <WhatsAppWidget />
</Layout>

<style is:global>
  /* Premium Custom Typography variables styling for Markdown rendered articles */
  .prose-custom h2 {
    font-family: "Plus Jakarta Sans", system-ui, -apple-system, sans-serif;
    font-size: 1.625rem;
    font-weight: 800;
    color: var(--color-text-main);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    line-height: 1.3;
    letter-spacing: -0.02em;
  }
  
  .prose-custom h3 {
    font-family: "Plus Jakarta Sans", system-ui, -apple-system, sans-serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text-main);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }

  .prose-custom p {
    font-size: 1.05rem;
    color: var(--color-text-muted);
    line-height: 1.75;
    margin-bottom: 1.5rem;
  }

  .prose-custom strong {
    color: var(--color-text-main);
    font-weight: 700;
  }

  .prose-custom ul {
    list-style-type: disc;
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
    margin-top: -0.5rem;
  }

  .prose-custom li {
    font-size: 1.05rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: 0.5rem;
  }

  .prose-custom blockquote {
    border-left: 4px solid var(--color-primary);
    background-color: var(--color-bg-secondary);
    padding: 1.25rem 1.75rem;
    border-radius: 0 0.75rem 0.75rem 0;
    font-style: italic;
    color: var(--color-text-muted);
    margin: 2rem 0;
  }
  
  .prose-custom em {
    font-style: italic;
  }
</style>

<script define:vars={{ title: post.data.title }}>
  document.addEventListener('DOMContentLoaded', () => {
    const waBtn = document.getElementById('whatsapp-share-btn');
    if (waBtn) {
      waBtn.href = `https://api.whatsapp.com/send?text=${encodeURIComponent(title + ' ' + window.location.href)}`;
    }
  });
</script>
