---
// Travel Osing Landing Page
// Refactored to use modular components, TailwindCSS, and Layout.astro.
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import IntroStats from '../components/IntroStats.astro';
import TopDestinations from '../components/TopDestinations.astro';
import CulturalBanner from '../components/CulturalBanner.astro';
import Testimonials from '../components/Testimonials.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
	<!-- Navigation Header -->
	<Navbar />

	<main>
		<!-- Hero Section -->
		<Hero />

		<!-- Intro & Statistik Section -->
		<IntroStats />

		<!-- Top Destinasi Section -->
		<TopDestinations />

		<!-- Feature Banner (Cultural Experience) -->
		<CulturalBanner />

		<!-- Testimoni Section -->
		<Testimonials />
	</main>

	<!-- Footer Section -->
	<Footer />
</Layout>
